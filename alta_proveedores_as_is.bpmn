<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <process id="Process_AsIs" name="Alta de Proveedores (As-Is)" isExecutable="false">
    <laneSet id="LaneSet_1">
      <lane id="Lane_Solicitante" name="Solicitante (Compras)">
        <flowNodeRef>StartEvent_1</flowNodeRef>
        <flowNodeRef>Task_LlenarForm</flowNodeRef>
        <flowNodeRef>Task_EnviarEmail</flowNodeRef>
      </lane>
      <lane id="Lane_Admin" name="Administrativo (Compras)">
        <flowNodeRef>Task_RecibirForm</flowNodeRef>
        <flowNodeRef>Task_BuscarDuplicados</flowNodeRef>
        <flowNodeRef>Gateway_Existe</flowNodeRef>
        <flowNodeRef>Task_VerificarFiscal</flowNodeRef>
        <flowNodeRef>Gateway_Aprobacion</flowNodeRef>
        <flowNodeRef>Task_PedirAprobEmail</flowNodeRef>
        <flowNodeRef>EndEvent_Duplicado</flowNodeRef>
        <flowNodeRef>EndEvent_Alta</flowNodeRef>
        <flowNodeRef>Task_RegistrarPlanilla</flowNodeRef>
      </lane>
      <lane id="Lane_Jefe" name="Jefe de Compras">
        <flowNodeRef>Task_Revisar</flowNodeRef>
        <flowNodeRef>Gateway_Aprueba</flowNodeRef>
        <flowNodeRef>EndEvent_Rechazo</flowNodeRef>
        <flowNodeRef>Task_NotifRechazo</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent_1" name="Necesidad de nuevo proveedor">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <task id="Task_LlenarForm" name="Llenar formulario en papel">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="Task_EnviarEmail" name="Enviar formulario por email">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="Task_RecibirForm" name="Recibir y revisar formulario">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
    </task>
    <task id="Task_BuscarDuplicados" name="Buscar duplicados en planilla Excel">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Existe" name="¿Ya existe?">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_ExisteSi</outgoing>
      <outgoing>Flow_ExisteNo</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_Duplicado" name="Fin - Duplicado">
      <incoming>Flow_ExisteSi</incoming>
    </endEvent>
    <task id="Task_VerificarFiscal" name="Verificar condición fiscal manualmente">
      <incoming>Flow_ExisteNo</incoming>
      <outgoing>Flow_6</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Aprobacion" name="¿Requiere aprobación?">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_AprobNo</outgoing>
      <outgoing>Flow_AprobSi</outgoing>
    </exclusiveGateway>
    <task id="Task_RegistrarPlanilla" name="Registrar proveedor en planilla">
      <incoming>Flow_AprobNo</incoming>
      <incoming>Flow_JefeAprueba</incoming>
      <outgoing>Flow_Fin</outgoing>
    </task>
    <task id="Task_PedirAprobEmail" name="Enviar email pidiendo aprobación">
      <incoming>Flow_AprobSi</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <endEvent id="EndEvent_Alta" name="Fin - Proveedor registrado">
      <incoming>Flow_Fin</incoming>
    </endEvent>
    <task id="Task_Revisar" name="Revisar solicitud por email">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Aprueba" name="¿Aprueba?">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_JefeAprueba</outgoing>
      <outgoing>Flow_JefeRechaza</outgoing>
    </exclusiveGateway>
    <task id="Task_NotifRechazo" name="Notificar rechazo por email">
      <incoming>Flow_JefeRechaza</incoming>
      <outgoing>Flow_FinRechazo</outgoing>
    </task>
    <endEvent id="EndEvent_Rechazo" name="Fin - Rechazado">
      <incoming>Flow_FinRechazo</incoming>
    </endEvent>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_LlenarForm" />
    <sequenceFlow id="Flow_2" sourceRef="Task_LlenarForm" targetRef="Task_EnviarEmail" />
    <sequenceFlow id="Flow_3" sourceRef="Task_EnviarEmail" targetRef="Task_RecibirForm" />
    <sequenceFlow id="Flow_4" sourceRef="Task_RecibirForm" targetRef="Task_BuscarDuplicados" />
    <sequenceFlow id="Flow_5" sourceRef="Task_BuscarDuplicados" targetRef="Gateway_Existe" />
    <sequenceFlow id="Flow_ExisteSi" name="Sí" sourceRef="Gateway_Existe" targetRef="EndEvent_Duplicado" />
    <sequenceFlow id="Flow_ExisteNo" name="No" sourceRef="Gateway_Existe" targetRef="Task_VerificarFiscal" />
    <sequenceFlow id="Flow_6" sourceRef="Task_VerificarFiscal" targetRef="Gateway_Aprobacion" />
    <sequenceFlow id="Flow_AprobNo" name="No (Resp. Inscripto)" sourceRef="Gateway_Aprobacion" targetRef="Task_RegistrarPlanilla" />
    <sequenceFlow id="Flow_AprobSi" name="Sí (Monotrib./Exento)" sourceRef="Gateway_Aprobacion" targetRef="Task_PedirAprobEmail" />
    <sequenceFlow id="Flow_7" sourceRef="Task_PedirAprobEmail" targetRef="Task_Revisar" />
    <sequenceFlow id="Flow_8" sourceRef="Task_Revisar" targetRef="Gateway_Aprueba" />
    <sequenceFlow id="Flow_JefeAprueba" name="Sí" sourceRef="Gateway_Aprueba" targetRef="Task_RegistrarPlanilla" />
    <sequenceFlow id="Flow_JefeRechaza" name="No" sourceRef="Gateway_Aprueba" targetRef="Task_NotifRechazo" />
    <sequenceFlow id="Flow_Fin" sourceRef="Task_RegistrarPlanilla" targetRef="EndEvent_Alta" />
    <sequenceFlow id="Flow_FinRechazo" sourceRef="Task_NotifRechazo" targetRef="EndEvent_Rechazo" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_AsIs">
      <bpmndi:BPMNShape id="Lane_Jefe_di" bpmnElement="Lane_Jefe" isHorizontal="true">
        <dc:Bounds x="160" y="510" width="1340" height="200" />
      </bpmndi:BPMNShape>
