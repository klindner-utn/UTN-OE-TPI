          <dc:Bounds x="1409" y="603" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Duplicado_di" bpmnElement="EndEvent_Duplicado">
        <dc:Bounds x="712" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="763" y="273" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Alta_di" bpmnElement="EndEvent_Alta">
        <dc:Bounds x="1332" y="302" width="36" height="36" />
