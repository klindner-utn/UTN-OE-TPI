        <dc:Bounds x="1000" y="420" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Revisar_di" bpmnElement="Task_Revisar">
        <dc:Bounds x="1000" y="570" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Aprueba_di" bpmnElement="Gateway_Aprueba" isMarkerVisible="true">
        <dc:Bounds x="1135" y="585" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rechazo_di" bpmnElement="EndEvent_Rechazo">
        <dc:Bounds x="1362" y="592" width="36" height="36" />
