<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <process id="Process_ToBe" name="Alta de Proveedores (To-Be) - Chatbot" isExecutable="false">
    <laneSet id="LaneSet_1">
      <lane id="Lane_Solicitante" name="Solicitante (Compras)">
        <flowNodeRef>StartEvent_1</flowNodeRef>
        <flowNodeRef>Task_IniciarChat</flowNodeRef>
        <flowNodeRef>Task_IngresarDatos</flowNodeRef>
        <flowNodeRef>Task_CorregirCUIT</flowNodeRef>
        <flowNodeRef>EndEvent_Rechazo</flowNodeRef>
        <flowNodeRef>EndEvent_Confirmacion</flowNodeRef>
      </lane>
      <lane id="Lane_Bot" name="Sistema / Bot">
        <flowNodeRef>Task_SolicitarDatos</flowNodeRef>
        <flowNodeRef>Task_ValidarCUIT</flowNodeRef>
        <flowNodeRef>Task_VerificarExistencia</flowNodeRef>
        <flowNodeRef>Task_RegistrarAuto</flowNodeRef>
        <flowNodeRef>Task_EnviarAprobacion</flowNodeRef>
        <flowNodeRef>Task_NotificarRechazo</flowNodeRef>
        <flowNodeRef>Task_NotificarAlta</flowNodeRef>
        <flowNodeRef>Gateway_CUITValido</flowNodeRef>
        <flowNodeRef>Gateway_Existe</flowNodeRef>
        <flowNodeRef>Gateway_CondicionFiscal</flowNodeRef>
        <flowNodeRef>EndEvent_Duplicado</flowNodeRef>
      </lane>
      <lane id="Lane_Jefe" name="Jefe de Compras">
        <flowNodeRef>Task_RevisarSolicitud</flowNodeRef>
        <flowNodeRef>Task_RegistrarAprobado</flowNodeRef>
        <flowNodeRef>Gateway_Aprueba</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="StartEvent_1" name="Necesidad de alta">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <task id="Task_IniciarChat" name="Enviar comando /alta">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="Task_SolicitarDatos" name="Solicitar datos del proveedor">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="Task_IngresarDatos" name="Ingresar datos del proveedor">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
    </task>
    <task id="Task_ValidarCUIT" name="Validar formato CUIT">
      <incoming>Flow_4</incoming>
      <incoming>Flow_ReintentoCUIT</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <exclusiveGateway id="Gateway_CUITValido" name="¿CUIT válido?">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_CUITSi</outgoing>
      <outgoing>Flow_CUITNo</outgoing>
    </exclusiveGateway>
    <task id="Task_CorregirCUIT" name="Reingresar CUIT">
      <incoming>Flow_CUITNo</incoming>
      <outgoing>Flow_ReintentoCUIT</outgoing>
    </task>
    <task id="Task_VerificarExistencia" name="Consultar BD (¿existe CUIT?)">
      <incoming>Flow_CUITSi</incoming>
      <outgoing>Flow_6</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Existe" name="¿Ya registrado?">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_NoExiste</outgoing>
      <outgoing>Flow_SiExiste</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_Duplicado" name="Fin - Duplicado">
      <incoming>Flow_SiExiste</incoming>
    </endEvent>
    <exclusiveGateway id="Gateway_CondicionFiscal" name="¿Condición fiscal?">
      <incoming>Flow_NoExiste</incoming>
      <outgoing>Flow_RespInsc</outgoing>
      <outgoing>Flow_MonoExento</outgoing>
    </exclusiveGateway>
    <task id="Task_RegistrarAuto" name="Registrar proveedor en BD">
      <incoming>Flow_RespInsc</incoming>
      <outgoing>Flow_NotifAlta1</outgoing>
    </task>
    <task id="Task_EnviarAprobacion" name="Enviar solicitud al Jefe">
      <incoming>Flow_MonoExento</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <task id="Task_RevisarSolicitud" name="Revisar datos del proveedor">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
    <exclusiveGateway id="Gateway_Aprueba" name="¿Aprueba?">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_ApSi</outgoing>
      <outgoing>Flow_ApNo</outgoing>
    </exclusiveGateway>
    <task id="Task_RegistrarAprobado" name="Registrar proveedor en BD">
      <incoming>Flow_ApSi</incoming>
      <outgoing>Flow_AltaOK</outgoing>
    </task>
    <task id="Task_NotificarAlta" name="Confirmar alta al solicitante">
      <incoming>Flow_NotifAlta1</incoming>
      <incoming>Flow_AltaOK</incoming>
      <outgoing>Flow_FinOK</outgoing>
    </task>
    <task id="Task_NotificarRechazo" name="Informar rechazo al solicitante">
      <incoming>Flow_ApNo</incoming>
      <outgoing>Flow_1rhdaup</outgoing>
    </task>
    <endEvent id="EndEvent_Confirmacion" name="Fin - Alta exitosa">
      <incoming>Flow_FinOK</incoming>
    </endEvent>
    <endEvent id="EndEvent_Rechazo" name="Fin - Rechazado">
      <incoming>Flow_1rhdaup</incoming>
    </endEvent>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_IniciarChat" />
    <sequenceFlow id="Flow_2" sourceRef="Task_IniciarChat" targetRef="Task_SolicitarDatos" />
    <sequenceFlow id="Flow_3" sourceRef="Task_SolicitarDatos" targetRef="Task_IngresarDatos" />
    <sequenceFlow id="Flow_4" sourceRef="Task_IngresarDatos" targetRef="Task_ValidarCUIT" />
    <sequenceFlow id="Flow_5" sourceRef="Task_ValidarCUIT" targetRef="Gateway_CUITValido" />
    <sequenceFlow id="Flow_CUITSi" name="Sí" sourceRef="Gateway_CUITValido" targetRef="Task_VerificarExistencia" />
    <sequenceFlow id="Flow_CUITNo" name="No" sourceRef="Gateway_CUITValido" targetRef="Task_CorregirCUIT" />
    <sequenceFlow id="Flow_ReintentoCUIT" sourceRef="Task_CorregirCUIT" targetRef="Task_ValidarCUIT" />
    <sequenceFlow id="Flow_6" sourceRef="Task_VerificarExistencia" targetRef="Gateway_Existe" />
    <sequenceFlow id="Flow_SiExiste" name="Sí" sourceRef="Gateway_Existe" targetRef="EndEvent_Duplicado" />
    <sequenceFlow id="Flow_NoExiste" name="No" sourceRef="Gateway_Existe" targetRef="Gateway_CondicionFiscal" />
    <sequenceFlow id="Flow_RespInsc" name="Resp. Inscripto" sourceRef="Gateway_CondicionFiscal" targetRef="Task_RegistrarAuto" />
    <sequenceFlow id="Flow_MonoExento" name="Monotrib./Exento" sourceRef="Gateway_CondicionFiscal" targetRef="Task_EnviarAprobacion" />
    <sequenceFlow id="Flow_NotifAlta1" sourceRef="Task_RegistrarAuto" targetRef="Task_NotificarAlta" />
    <sequenceFlow id="Flow_7" sourceRef="Task_EnviarAprobacion" targetRef="Task_RevisarSolicitud" />
    <sequenceFlow id="Flow_8" sourceRef="Task_RevisarSolicitud" targetRef="Gateway_Aprueba" />
    <sequenceFlow id="Flow_ApSi" name="Sí" sourceRef="Gateway_Aprueba" targetRef="Task_RegistrarAprobado" />
    <sequenceFlow id="Flow_ApNo" name="No" sourceRef="Gateway_Aprueba" targetRef="Task_NotificarRechazo" />
    <sequenceFlow id="Flow_AltaOK" sourceRef="Task_RegistrarAprobado" targetRef="Task_NotificarAlta" />
    <sequenceFlow id="Flow_FinOK" sourceRef="Task_NotificarAlta" targetRef="EndEvent_Confirmacion" />
    <sequenceFlow id="Flow_1rhdaup" sourceRef="Task_NotificarRechazo" targetRef="EndEvent_Rechazo" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_ToBe">
      <bpmndi:BPMNShape id="Lane_Jefe_di" bpmnElement="Lane_Jefe" isHorizontal="true">
        <dc:Bounds x="160" y="530" width="1640" height="200" />
