        <di:waypoint x="730" y="400" />
        <di:waypoint x="775" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CUITSi_di" bpmnElement="Flow_CUITSi">
